# Secrets - never commit
*.input
!*.input.example
!detection_logics/dns_suspicious_string.input
.env
.env.*
!.env.example

# Scenario inputs and outputs
# Ignore all files in input and output scenario folders, except placeholders, scripts, and example templates
scenarios/**/input/*
!scenarios/**/input/.gitkeep
!scenarios/**/input/*.py
!scenarios/**/input/*.example

scenarios/**/output/*
!scenarios/**/output/.gitkeep
!scenarios/**/output/*.example

# Exclude company-specific configurations/exclusions (tracked: *.example)
**/*company-specific.conf
!**/*company-specific.conf.example

# Punycode IDN scenario config
scenarios/punycode_encoded_international_domain_names/config/authoritative_dns_nameservers.conf

# Python / Virtual Environments
.venv/
venv/
.jupyter_venv/
*_venv/
**/venv/
**/.venv/
**/_venv/
**/*_venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
speclan/.local/

# OS
.DS_Store
Thumbs.db

# Office documents
*.docx
*.pptx

# "Hide Env" config file extension
.hide

# PEAK Compliance Reports
scenarios/**/.peak_compliance_report.md
peak_compliance_results.json

# KPIs results
scenarios/kpis.csv
!scenarios/kpis.csv.example

# EvidenceForge generated files
*_evidenceforge.*