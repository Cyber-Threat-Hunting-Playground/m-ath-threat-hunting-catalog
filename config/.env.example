# SentinelOne API configuration
SENTINELONE_URL=https://<your-s1-tenant-url>
SENTINELONE_TOKEN=<your-s1-service-token>
SENTINELONE_VERIFY_SSL=true
SENTINELONE_TEAM_EMAILS=["admin@company.com"]

# OpenAI-compatible LLM configuration
LLM_API_KEY=<your-openai-compatible-api-key>
LLM_API_BASE=http://localhost:11434/v1
LLM_MODEL_NAME=gpt-4-turbo

# Company Details for Pre-Commit Sanitization Checks
# The pre-commit script will block commits containing these sensitive values.
# Use comma-separated values for multiple entries.
COMPANY_NAMES=MyCompany,MyCompanyInc
COMPANY_DOMAINS=mycompany.com,mycompany.org
COMPANY_URLS=https://mycompany.sentinelone.net,https://api.mycompany.com
COMPANY_EMAILS=admin@mycompany.com

